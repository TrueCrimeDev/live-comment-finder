{
  "name": "live-comment-finder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node test/e2e/youtube-smoke.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0",
    "@eslint/js": "9.11.1",
    "@types/chrome": "0.0.270",
    "eslint": "9.11.1",
    "jsdom": "25.0.1",
    "pngjs": "7.0.0",
    "prettier": "3.3.3",
    "puppeteer": "25.1.0",
    "typescript": "5.6.2",
    "typescript-eslint": "8.8.0",
    "vite": "5.4.8",
    "vitest": "2.1.2"
  }
}
